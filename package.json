{
  "name": "zhixing",
  "private": true,
  "description": "知行 — 智能体引擎",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "pnpm -r run clean",
    "playground": "node --import=tsx/esm playground/chat.ts",
    "cli": "node --import=tsx/esm packages/cli/src/index.ts",
    "cli:build": "pnpm --filter @zhixing/cli build",
    "serve": "node --import=tsx/esm packages/cli/src/index.ts serve"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "tsx": "^4.21.0"
  }
}
