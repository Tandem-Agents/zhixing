{
  "name": "@zhixing/orchestrator",
  "version": "0.1.0",
  "description": "知行编排器 — Agent Runtime 装配 + 子 Agent 生命周期 + Task 工具",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js"
    },
    "./profile": {
      "types": "./dist/profile/index.d.ts",
      "import": "./dist/profile/index.js"
    },
    "./subagent": {
      "types": "./dist/subagent/index.d.ts",
      "import": "./dist/subagent/index.js"
    },
    "./confirmation": {
      "types": "./dist/confirmation/index.d.ts",
      "import": "./dist/confirmation/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zhixing/core": "workspace:*",
    "@zhixing/network": "workspace:*",
    "@zhixing/providers": "workspace:*",
    "@zhixing/tools-builtin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
