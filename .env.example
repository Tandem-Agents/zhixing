# 知行 — 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Key
#
# cp .env.example .env
#
# 然后编辑 .env 填入真实的 key 值
# .env 文件已被 .gitignore 忽略，不会被提交

# ─── 硅基流动（SiliconFlow）───
SILICONFLOW_API_KEY=

# ─── DeepSeek ───
# DEEPSEEK_API_KEY=

# ─── MiniMax 官方 ───
# MINIMAX_API_KEY=

# ─── 通义千问（DashScope）───
# DASHSCOPE_API_KEY=

# ─── Kimi（Moonshot）───
# MOONSHOT_API_KEY=

# ─── 智谱 GLM ───
# GLM_API_KEY=

# ─── OpenAI ───
# OPENAI_API_KEY=

# ─── Anthropic ───
# ANTHROPIC_API_KEY=
